rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 頭像：登入用戶只能寫自己的 avatars/{uid}.webp
    match /avatars/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && filename == request.auth.uid + '.webp'
                   && request.resource.size < 200 * 1024
                   && request.resource.contentType == 'image/webp';
      allow delete: if request.auth != null
                    && filename == request.auth.uid + '.webp';
    }

    // 評論照片：登入用戶可上傳（限 webp / 300KB），禁止客戶端刪除
    // 刪除由管理員在 Firebase Console 手動處理（待實作 admin 孤兒清理工具）
    match /reviews/{shopId}/{reviewId}/{file} {
      allow read:   if true;
      allow write:  if request.auth != null
                    && request.resource.size < 300 * 1024
                    && request.resource.contentType == 'image/webp';
      allow delete: if false;
    }

    // 菜單照片：登入用戶可上傳（限 webp / 300KB），禁止客戶端刪除
    // 刪除由管理員在 Firebase Console 手動處理（待實作 admin 孤兒清理工具）
    match /menus/{shopId}/{file} {
      allow read:   if true;
      allow write:  if request.auth != null
                    && request.resource.size < 300 * 1024
                    && request.resource.contentType == 'image/webp';
      allow delete: if false;
    }
  }
}
