rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 頭像：登入用戶只能寫自己的，任何人可讀
    match /avatars/{uid}.webp {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 200 * 1024   // 最大 200KB
                   && request.resource.contentType == 'image/webp';
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // 評論照片：登入用戶可上傳自己的，任何人可讀，本人或 admin 可刪
    match /reviews/{shopId}/{reviewId}/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 600 * 1024
                   && request.resource.contentType == 'image/webp';
      allow delete: if request.auth != null;
    }
  }
}
