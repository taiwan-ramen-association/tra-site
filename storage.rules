rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 頭像：登入用戶只能寫自己的 avatars/{uid}.webp
    match /avatars/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && filename == request.auth.uid + '.webp'
                   && request.resource.size < 200 * 1024
                   && request.resource.contentType == 'image/webp';
      allow delete: if request.auth != null
                    && filename == request.auth.uid + '.webp';
    }

    // 評論照片：登入用戶可上傳，任何人可讀，本人或 admin 可刪
    match /reviews/{shopId}/{reviewId}/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 600 * 1024
                   && request.resource.contentType == 'image/webp';
      allow delete: if request.auth != null;
    }
  }
}
